<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Minimal Canvas Game</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            overflow: hidden;
            background-color: #1a1a1a;
            touch-action: none;
        }
        canvas {
            display: block;
        }
    </style>
</head>
<body>

<canvas id="gameCanvas"></canvas>

<script>
    // --- Configuration & State ---
    const canvas = document.getElementById('gameCanvas');
    const ctx = canvas.getContext('2d');
    
    let lastTime = 0;
    
    const player = {
        radius: 25,
        color: '#00d2ff'
    };

    // Game State
    let score = 0;
    let gameOver = false;

    // World State
    const world = { x: 0, y: 0 };
    const speed = 200;
    const worldObjects = [];
    const inputSmooth = { x: 0, y: 0 };

    // Enemy State
    const enemies = [];
    let spawnTimer = 0;
    const spawnInterval = 1;
    const maxEnemies = 20;
    const enemyBaseSpeed = 80;
    const enemySize = 30;

    // Knife State
    const knives = [];
    let shootTimer = 0;
    const shootInterval = 1;
    const knifeSpeed = 300;
    const knifeSize = 10;

    // Joystick State
    const joystick = { 
        x: 0, 
        y: 0, 
        active: false,
        thumbX: 0,
        thumbY: 0
    };
    const joyConfig = {
        radius: 60,
        thumbRadius: 25,
        baseX: 0,
        baseY: 0
    };
    let activeTouchId = null;

    // Init World Objects (Simple Grid)
    for (let i = -5; i <= 5; i++) {
        for (let j = -5; j <= 5; j++) {
            if (i === 0 && j === 0) continue;
            worldObjects.push({
                x: i * 100,
                y: j * 100,
                w: 40,
                h: 40,
                color: '#333'
            });
        }
    }

    // --- System: Resize Handling ---
    function resize() {
        const dpr = window.devicePixelRatio || 1;
        const width = window.innerWidth;
        const height = window.innerHeight;

        canvas.width = width * dpr;
        canvas.height = height * dpr;
        ctx.scale(dpr, dpr);
        canvas.style.width = width + 'px';
        canvas.style.height = height + 'px';

        const padding = 80;
        joyConfig.baseX = padding;
        joyConfig.baseY = height - padding;
        
        joystick.thumbX = joyConfig.baseX;
        joystick.thumbY = joyConfig.baseY;
    }

    window.addEventListener('resize', resize);
    resize();

    // --- System: Input Handling ---
    function updateJoystick(tx, ty) {
        const dx = tx - joyConfig.baseX;
        const dy = ty - joyConfig.baseY;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const angle = Math.atan2(dy, dx);
        const clampedDist = Math.min(dist, joyConfig.radius);
        
        joystick.x = (clampedDist / joyConfig.radius) * Math.cos(angle);
        joystick.y = (clampedDist / joyConfig.radius) * Math.sin(angle);
        joystick.thumbX = joyConfig.baseX + Math.cos(angle) * clampedDist;
        joystick.thumbY = joyConfig.baseY + Math.sin(angle) * clampedDist;
    }

    function resetJoystick() {
        joystick.active = false;
        joystick.x = 0;
        joystick.y = 0;
        joystick.thumbX = joyConfig.baseX;
        joystick.thumbY = joyConfig.baseY;
        activeTouchId = null;
    }

    window.addEventListener('touchstart', (e) => {
        e.preventDefault();
        
        // Restart on game over
        if (gameOver) {
            score = 0;
            enemies.length = 0;
            knives.length = 0;
            world.x = 0;
            world.y = 0;
            gameOver = false;
            return;
        }

        if (joystick.active) return;
        const touch = e.changedTouches[0];
        const dx = touch.clientX - joyConfig.baseX;
        const dy = touch.clientY - joyConfig.baseY;
        if (Math.sqrt(dx * dx + dy * dy) <= joyConfig.radius) {
            joystick.active = true;
            activeTouchId = touch.identifier;
            updateJoystick(touch.clientX, touch.clientY);
        }
    }, { passive: false });

    window.addEventListener('touchmove', (e) => {
        e.preventDefault();
        if (!joystick.active) return;
        for (let i = 0; i < e.changedTouches.length; i++) {
            if (e.changedTouches[i].identifier === activeTouchId) {
                updateJoystick(e.changedTouches[i].clientX, e.changedTouches[i].clientY);
                break;
            }
        }
    }, { passive: false });

    window.addEventListener('touchend', (e) => {
        e.preventDefault();
        for (let i = 0; i < e.changedTouches.length; i++) {
            if (e.changedTouches[i].identifier === activeTouchId) {
                resetJoystick();
                break;
            }
        }
    });

    // --- Game Logic ---
    function update(deltaTime) {
        if (gameOver) return;

        const dpr = window.devicePixelRatio || 1;
        const width = canvas.width / dpr;
        const height = canvas.height / dpr;

        // Smooth input
        inputSmooth.x += (joystick.x - inputSmooth.x) * 0.2;
        inputSmooth.y += (joystick.y - inputSmooth.y) * 0.2;

        // Move world
        world.x -= inputSmooth.x * speed * deltaTime;
        world.y -= inputSmooth.y * speed * deltaTime;

        // Player World Position
        const pWX = -world.x + width / 2;
        const pWY = -world.y + height / 2;

        // Spawn Enemies
        spawnTimer += deltaTime;
        if (spawnTimer >= spawnInterval && enemies.length < maxEnemies) {
            const side = Math.floor(Math.random() * 4);
            const pad = 50;
            let sx, sy;
            if (side === 0) { sx = Math.random() * width; sy = -pad; }
            else if (side === 1) { sx = Math.random() * width; sy = height + pad; }
            else if (side === 2) { sx = -pad; sy = Math.random() * height; }
            else { sx = width + pad; sy = Math.random() * height; }

            enemies.push({
                x: sx - world.x,
                y: sy - world.y,
                speed: enemyBaseSpeed + Math.random() * 40,
                size: enemySize
            });
            spawnTimer = 0;
        }

        // Update Enemies
        for (let i = enemies.length - 1; i >= 0; i--) {
            const e = enemies[i];
            const dx = pWX - e.x;
            const dy = pWY - e.y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            
            if (dist > 0) {
                e.x += (dx / dist) * e.speed * deltaTime;
                e.y += (dy / dist) * e.speed * deltaTime;
            }

            // Enemy vs Player Collision
            if (dist < player.radius + e.size / 2) {
                gameOver = true;
            }

            if (dist > width * 2 + height * 2) {
                enemies.splice(i, 1);
            }
        }

        // Spawn Knives
        shootTimer += deltaTime;
        if (shootTimer >= shootInterval) {
            for (let i = 0; i < 3; i++) {
                const angle = Math.random() * Math.PI * 2;
                knives.push({
                    x: pWX,
                    y: pWY,
                    vx: Math.cos(angle) * knifeSpeed,
                    vy: Math.sin(angle) * knifeSpeed,
                    size: knifeSize
                });
            }
            shootTimer = 0;
        }

        // Update Knives & Check Collisions
        for (let i = knives.length - 1; i >= 0; i--) {
            const k = knives[i];
            k.x += k.vx * deltaTime;
            k.y += k.vy * deltaTime;

            const sx = k.x + world.x;
            const sy = k.y + world.y;

            // Knife vs Enemy Collision
            let hit = false;
            for (let j = enemies.length - 1; j >= 0; j--) {
                const e = enemies[j];
                const edx = k.x - e.x;
                const edy = k.y - e.y;
                const edist = Math.sqrt(edx * edx + edy * edy);
                
                if (edist < k.size + e.size / 2) {
                    enemies.splice(j, 1);
                    score++;
                    hit = true;
                    break;
                }
            }

            if (hit) {
                knives.splice(i, 1);
                continue;
            }

            // Cleanup far knives
            if (sx < -width || sx > width * 2 || sy < -height || sy > height * 2) {
                knives.splice(i, 1);
            }
        }
    }

    // --- Rendering ---
    function render() {
        const dpr = window.devicePixelRatio || 1;
        const width = canvas.width / dpr;
        const height = canvas.height / dpr;

        ctx.clearRect(0, 0, width, height);

        // Draw World Objects
        worldObjects.forEach(obj => {
            ctx.fillStyle = obj.color;
            ctx.fillRect(obj.x + world.x, obj.y + world.y, obj.w, obj.h);
        });

        // Draw Knives
        ctx.fillStyle = '#ffff00';
        knives.forEach(k => {
            ctx.fillRect(k.x + world.x - k.size/2, k.y + world.y - k.size/2, k.size, k.size);
        });

        // Draw Enemies
        ctx.fillStyle = '#ff4444';
        enemies.forEach(e => {
            ctx.fillRect(e.x + world.x - e.size/2, e.y + world.y - e.size/2, e.size, e.size);
        });

        // Draw Player
        ctx.fillStyle = player.color;
        ctx.beginPath();
        ctx.arc(width / 2, height / 2, player.radius, 0, Math.PI * 2);
        ctx.fill();

        // Draw Joystick
        ctx.fillStyle = 'rgba(255, 255, 255, 0.1)';
        ctx.beginPath();
        ctx.arc(joyConfig.baseX, joyConfig.baseY, joyConfig.radius, 0, Math.PI * 2);
        ctx.fill();

        ctx.fillStyle = 'rgba(255, 255, 255, 0.5)';
        ctx.beginPath();
        ctx.arc(joystick.thumbX, joystick.thumbY, joyConfig.thumbRadius, 0, Math.PI * 2);
        ctx.fill();

        // Draw Score
        ctx.fillStyle = '#ffffff';
        ctx.font = '24px Arial';
        ctx.textAlign = 'right';
        ctx.fillText('Score: ' + score, width - 20, 40);

        // Draw Game Over
        if (gameOver) {
            ctx.fillStyle = 'rgba(0, 0, 0, 0.7)';
            ctx.fillRect(0, 0, width, height);
            
            ctx.fillStyle = '#ffffff';
            ctx.font = '48px Arial';
            ctx.textAlign = 'center';
            ctx.fillText('GAME OVER', width / 2, height / 2 - 30);
            
            ctx.font = '24px Arial';
            ctx.fillText('Tap to restart', width / 2, height / 2 + 30);
        }
    }

    // --- Game Loop ---
    function gameLoop(timestamp) {
        const deltaTime = (timestamp - lastTime) / 1000;
        lastTime = timestamp;
        update(deltaTime);
        render();
        requestAnimationFrame(gameLoop);
    }

    requestAnimationFrame(gameLoop);

</script>
</body>
</html>
